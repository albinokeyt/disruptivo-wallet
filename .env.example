# Puerto del servidor (EasyPanel: 8080)
PORT=8080

# Postgres y Redis (en EasyPanel usa los nombres internos de los servicios)
DATABASE_URL=postgres://postgres:CAMBIA_ESTO@disruptivo-wallet-db:5432/disruptivo_wallet
REDIS_URL=redis://disruptivo-wallet-redis:6379

# Login del panel de administración
ADMIN_USER=admin
ADMIN_PASS=CAMBIA_ESTO

# URL pública de la app (sin barra final). Necesaria para el OAuth de GHL.
APP_BASE_URL=https://wallet.tudominio.com

# Límite de peticiones por minuto y por API key en la API pública (opcional, def. 600)
API_RATE_PER_MIN=600

# --- Solo para docker-compose (autohospedaje/local) ---
# Contraseña de Postgres del compose y puerto público del contenedor app.
POSTGRES_PASSWORD=cambia_esto
APP_PORT=8080
